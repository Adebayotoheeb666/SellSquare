# SellSquare Environment Variables Example
# Copy this file to .env and fill in the values

# --- CORE SERVER & DATABASE ---
PORT=4000
MONGO_URI=mongodb://localhost:27017/sellsquare
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CLIENT_URL=http://localhost:3000

# --- AUTHENTICATION & SECURITY ---
JWT_SECRET=your_super_secret_jwt_key_here
BUYER_JWT_SECRET=your_super_secret_buyer_jwt_key_here
PUBLIC_PARTNER_JWT_SECRET=your_super_secret_partner_jwt_key_here

# --- GOOGLE OAUTH ---
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_BUYER_CALLBACK_URL=http://localhost:4000/api/buyer/auth/google/callback

# --- AI & CONTENT SERVICES ---
OPENAI_API_KEY=sk-xxxx
CLAUDE_API_KEY=sk-ant-xxxx
ELEVENLABS_API_KEY=xxxx
ELEVENLABS_VOICE_ID=xxxx

# --- STORAGE & MEDIA (AWS S3 & CLOUDINARY) ---
AWS_BUCKET_NAME=your-bucket-name
AWS_BUCKET_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUD_NAME=your-cloud-name
CLOUD_API_KEY=your-cloud-api-key
CLOUD_API_SECRET=your-cloud-api-secret

# --- SMS & MESSAGING (TWILIO) ---
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_PHONE_NUMBER=+1234567890

# --- WHATSAPP (DIRECT META API) ---
WHATSAPP_ACCESS_TOKEN=xxxx
WHATSAPP_PHONE_NUMBER_ID=xxxx

# --- INSTAGRAM & TIKTOK ---
INSTAGRAM_ACCESS_TOKEN=xxxx
INSTAGRAM_BUSINESS_ACCOUNT_ID=xxxx
TIKTOK_CLIENT_ID=xxxx
TIKTOK_CLIENT_SECRET=xxxx
TIKTOK_ACCESS_TOKEN=xxxx
TIKTOK_REFRESH_TOKEN=xxxx
TIKTOK_REDIRECT_URI=http://localhost:4000/api/integrations/tiktok/callback

# --- EMAIL (MAILGUN & OTHERS) ---
MAILGUN_API_KEY=xxxx
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_API_URL=https://api.mailgun.net
EMAIL_FROM=noreply@sellsquare.io
EMAIL_API_KEY=xxxx
EMAIL_SENDER=noreply@sellsquare.io
EMAIL_PROVIDER=mailgun
EMAIL_USER=xxxx
EMAIL_PASS=xxxx

# --- NOTIFICATIONS ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxx
SLACK_BOT_TOKEN=xoxb-xxxx
SLACK_NOTIFICATION_CHANNEL=#automation-alerts

# --- PAYMENTS ---
PAYSTACK_SECRET_KEY=sk_test_xxxx

# --- FLUTTERWAVE ---
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxx-X
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxx-X

# --- MARKETPLACE & ADMIN ---
ADMIN_EMAILS=admin@sellsquare.io,dev@sellsquare.io
SUPERADMIN_BUSINESS_ID=65xxxxxxxxxxxxxxxxxxxxxx
MARKETPLACE_WEBHOOK_LEGACY_ENABLED=true
MARKETPLACE_WEBHOOK_V2_ENABLED=true
MARKETPLACE_WEBHOOK_DUAL_RUN=false
